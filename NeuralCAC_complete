    for (xb,) in dl:
        z, xr = dcn(xb)
        dcn_opt.zero_grad(); nn.functional.mse_loss(xr, xb).backward(); dcn_opt.step()

dcn.eval()
with torch.no_grad():
    Ztr_d = dcn.encoder(X_train_t).cpu().numpy()
    Zva_d = dcn.encoder(X_val_t).cpu().numpy()
    Zte_d = dcn.encoder(X_test_t).cpu().numpy()

