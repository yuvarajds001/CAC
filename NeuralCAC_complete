class Encoder(nn.Module):
    def __init__(self, input_dim, hidden_dim, embed_dim=64):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(input_dim, hidden_dim),
            nn.BatchNorm1d(hidden_dim),
            nn.ReLU(),
            nn.Dropout(0.3),
            nn.Linear(hidden_dim, embed_dim),
            nn.BatchNorm1d(embed_dim),
            nn.ReLU(),
        )
    def forward(self, x): return self.net(x)


class Decoder(nn.Module):
    def __init__(self, embed_dim, hidden_dim, output_dim):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(embed_dim, hidden_dim), nn.ReLU(),
            nn.Linear(hidden_dim, output_dim),
        )
    def forward(self, z): return self.net(z)


class LocalClassifier(nn.Module):
    def __init__(self, embed_dim=64):
        super().__init__()
        self.net = nn.Sequential(
            nn.Linear(embed_dim, 32), nn.ReLU(), nn.Dropout(0.2),
            nn.Linear(32, 1), nn.Sigmoid(),
        )
    def forward(self, z): return self.net(z).squeeze(-1)


class AMSoftmaxLoss(nn.Module):
    """
    Additive Margin Softmax loss.
    FIX-4: weight init on 2-D tensor (original used unsqueeze → wrong shape).
    """
    def __init__(self, embed_dim=64, num_classes=2, scale=30.0, margin=0.35):
        super().__init__()
        self.scale  = scale
        self.margin = margin
        self.weight = nn.Parameter(torch.randn(num_classes, embed_dim))
        nn.init.xavier_uniform_(self.weight)   # FIX-4
    def forward(self, z, labels):
        z_norm    = nn.functional.normalize(z, dim=1)
        w_norm    = nn.functional.normalize(self.weight, dim=1)
        cos_theta = z_norm @ w_norm.T
        one_hot   = torch.zeros_like(cos_theta)
        one_hot.scatter_(1, labels.long().unsqueeze(1), 1.0)
        logits = self.scale * (cos_theta - one_hot * self.margin)
        return nn.functional.cross_entropy(logits, labels.long())


# ═══════════════════════════════════════════════════════════════════════════════
# SECTION 3 — NEURALCAC TRAINING FUNCTION
# ═══════════════════════════════════════════════════════════════════════════════

def train_neuralcac(K, alpha, beta,
                    epochs=60, patience=8, lr=2e-3,
                    batch_size=128, delta=1e-8,
                    local_epochs=80, verbose=False):
    """
    Returns (test_auc, val_auc, cluster_aucs).

    Key fixes vs original:
      FIX-1  loss sign: + alpha * L_am  (was minus)
      FIX-3  empty cluster fallback to distance scores
      FIX-5  checkpoint selected by val_auc
    """
    EMBED   = 64
    HIDDEN  = max(64, INPUT_DIM // 2)

    encoder    = Encoder(INPUT_DIM, HIDDEN, EMBED).to(DEVICE)
    decoder    = Decoder(EMBED, HIDDEN, INPUT_DIM).to(DEVICE)
    am_loss_fn = AMSoftmaxLoss(EMBED, 2, 30.0, 0.35).to(DEVICE)

    params    = (list(encoder.parameters()) +
                 list(decoder.parameters()) +
                 list(am_loss_fn.parameters()))
    optimizer = optim.Adam(params, lr=lr, weight_decay=1e-4)
    loader    = DataLoader(TensorDataset(X_train_t, y_train_t),
                           batch_size=batch_size, shuffle=True)

    # ── Phase 1: pretrain autoencoder ──────────────────────────────────────
    for _ in range(15):
        encoder.train(); decoder.train()
        for xb, _ in loader:
            z    = encoder(xb)
            loss = nn.functional.mse_loss(decoder(z), xb)
            optimizer.zero_grad(); loss.backward(); optimizer.step()

    # ── Phase 2: init centroids via KMeans ─────────────────────────────────
    with torch.no_grad():
        Z0 = encoder(X_train_t).cpu().numpy()
    km        = KMeans(n_clusters=K, n_init=10, random_state=42)
    km.fit(Z0)
    centroids = torch.tensor(km.cluster_centers_, dtype=torch.float32).to(DEVICE)

    # ── Phase 3: joint training ─────────────────────────────────────────────
    best_val_auc, best_enc_state, best_centroids = 0.0, None, centroids.clone()
    pat = 0

    for epoch in range(epochs):
        encoder.train(); decoder.train(); am_loss_fn.train()
        for xb, yb in loader:
            z      = encoder(xb)
            L_rec  = nn.functional.mse_loss(decoder(z), xb)

            dists  = torch.cdist(z, centroids)
            asgn   = dists.argmin(dim=1)
            L_clu  = torch.tensor(0.0, device=DEVICE)
            for j in range(K):
                mask = (asgn == j)
                if mask.sum() > 1:
                    zj   = z[mask]
                    sse  = ((zj - centroids[j])**2).sum(dim=1).mean()
                    L_clu += sse / (zj.shape[0] - 1 + delta)

            L_am = am_loss_fn(z, yb)

            # FIX-1: correct sign — minimising L_am maximises class separation
            loss = L_rec + beta * L_clu + alpha * L_am
            optimizer.zero_grad(); loss.backward(); optimizer.step()

        # Update centroids
        with torch.no_grad():
            Za   = encoder(X_train_t)
            aasgn = torch.cdist(Za, centroids).argmin(dim=1)
            for j in range(K):
                m = (aasgn == j)
                if m.sum() > 0:
                    centroids[j] = Za[m].mean(dim=0)

        # Validate with distance scores (fast, consistent)
        encoder.eval()
        with torch.no_grad():
            Zv     = encoder(X_val_t)
            scores = -torch.cdist(Zv, centroids).min(dim=1).values.cpu().numpy()
        try:    val_auc = roc_auc_score(y_val, scores)
        except: val_auc = 0.5

        if val_auc > best_val_auc:
            best_val_auc   = val_auc
            best_enc_state = {k: v.clone() for k, v in encoder.state_dict().items()}
            best_centroids = centroids.clone()
            pat = 0
        else:
            pat += 1
            if pat >= patience: break

    encoder.load_state_dict(best_enc_state)
    centroids = best_centroids

    # ── Phase 4: per-cluster local classifiers ──────────────────────────────
    encoder.eval()
    with torch.no_grad():
        Z_tr  = encoder(X_train_t)
        Z_te  = encoder(X_test_t)
        atr   = torch.cdist(Z_tr, centroids).argmin(dim=1)
        ate   = torch.cdist(Z_te, centroids).argmin(dim=1)

    # FIX-3: start with distance-based fallback, overwrite where classifier trained
    all_preds = -torch.cdist(Z_te, centroids).min(dim=1).values.cpu().numpy()

    bce  = nn.BCELoss()
    clfs = nn.ModuleList([LocalClassifier(EMBED).to(DEVICE) for _ in range(K)])
    cluster_aucs = []

    for j in range(K):
        mtr = (atr == j); mte = (ate == j)
        if mtr.sum() < 10 or mte.sum() < 2:
            cluster_aucs.append(None)
            continue

        Zj_tr = Z_tr[mtr].detach();  yj_tr = y_train_t[mtr]
        Zj_te = Z_te[mte].detach();  yj_te = y_test_t[mte].cpu().numpy()

        clf     = clfs[j]
        clf_opt = optim.Adam(clf.parameters(), lr=1e-3, weight_decay=1e-4)
        n_ep    = max(20, min(local_epochs, len(Zj_tr) // 2))

        ll = DataLoader(TensorDataset(Zj_tr, yj_tr),
                        batch_size=min(64, len(Zj_tr)), shuffle=True)
        clf.train()
        for _ in range(n_ep):
            for zb, yb in ll:
                p = clf(zb)
                clf_opt.zero_grad(); bce(p, yb).backward(); clf_opt.step()

        clf.eval()
        with torch.no_grad():
            pj = clf(Zj_te).cpu().numpy()
        try:    auc = roc_auc_score(yj_te, pj)
        except: auc = 0.5
        cluster_aucs.append(auc)

        # FIX-3: overwrite fallback with classifier prediction
        mte_np = mte.cpu().numpy().astype(bool)
        all_preds[mte_np] = pj

    global_auc = roc_auc_score(y_test, all_preds)
    sizes      = [(ate == j).sum().item() for j in range(K)]

    if verbose:
        fmt = [round(a,4) if a is not None else None for a in cluster_aucs]
        print(f"    K={K} α={alpha} β={beta} → "
              f"val:{best_val_auc:.4f}  test:{global_auc:.4f}  "
              f"clusters:{sizes}  local:{fmt}")

    return global_auc, best_val_auc, cluster_aucs


