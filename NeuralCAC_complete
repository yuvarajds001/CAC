class DCN(nn.Module):
    def __init__(self, input_dim, embed_dim=64):
        super().__init__()
        h = max(64, input_dim//2)
        self.encoder = nn.Sequential(
            nn.Linear(input_dim,h), nn.BatchNorm1d(h), nn.ReLU(),
            nn.Linear(h, embed_dim), nn.BatchNorm1d(embed_dim), nn.ReLU())
        self.decoder = nn.Sequential(
            nn.Linear(embed_dim,h), nn.ReLU(), nn.Linear(h, input_dim))
    def forward(self, x):
        z = self.encoder(x); return z, self.decoder(z)

dcn     = DCN(INPUT_DIM, 64).to(DEVICE)   # FIX-11: auto dim
