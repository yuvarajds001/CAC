# ── Helper: cluster-then-predict with fallback ──────────────────────────────
def cluster_predict(Xtr, ytr, Xva, yva, Xte, yte,
                    atr, ava, ate, K, clf_fn):
    """
    FIX-9: global LR fallback instead of 0.0 for empty/tiny clusters.
    FIX-10: caller loops K=2..5 and picks best by val AUC.
    """
    fb = LogisticRegression(max_iter=1000, random_state=42).fit(Xtr, ytr)
    vp = fb.predict_proba(Xva)[:,1].copy()
    tp = fb.predict_proba(Xte)[:,1].copy()
    for j in range(K):
        mtr=(atr==j); mva=(ava==j); mte=(ate==j)
        if mtr.sum() < 10: continue
        clf = clf_fn().fit(Xtr[mtr], ytr[mtr])
        if mva.sum() >= 2: vp[mva] = clf.predict_proba(Xva[mva])[:,1]
        if mte.sum() >= 2: tp[mte] = clf.predict_proba(Xte[mte])[:,1]
    return roc_auc_score(yva, vp), roc_auc_score(yte, tp)


